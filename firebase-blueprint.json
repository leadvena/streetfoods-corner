{
  "entities": {
    "MenuItem": {
      "title": "Menu Item",
      "description": "An item available for order on the menu",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Mains", "Sides", "Drinks", "Desserts"] },
        "image": { "type": "string" },
        "isAvailable": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["New", "Preparing", "Ready", "Completed"] },
        "type": { "type": "string", "enum": ["Delivery", "Pickup"] },
        "notes": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "phone", "items", "total", "status", "timestamp"]
    },
    "Admin": {
      "title": "Admin",
      "description": "System administrator user",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "manager"] }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "menu": {
      "schema": "MenuItem",
      "description": "Collection of street food menu items"
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "admins": {
      "schema": "Admin",
      "description": "Collection of authorized admin users (UID as doc ID)"
    }
  }
}
